# Vast.ai credentials — used by the `vastai` SDK
VASTAI_API_KEY=your_vastai_api_key_here

# Serverless endpoint ID OR name to invoke (one is enough)
VASTAI_ENDPOINT_ID=25323
# VASTAI_ENDPOINT_NAME=deployment-voxcpm2-tts-default

# Remote function name on the deployment (default: generate_speech)
# VASTAI_REMOTE_FUNC=generate_speech

# Web login credentials
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=password

# Session signing secret — set a long random string for production.
# If unset, a random one is generated at boot (logins won't survive restarts).
SESSION_SECRET=

# Web server bind config
HOST=0.0.0.0
PORT=8000
